# ── Nakama Server Connection ─────────────────────────────────
# Copy this file to .env.local for local development
# Set these as Environment Variables in Netlify for production

# Local dev (Docker):
VITE_NAKAMA_HOST=127.0.0.1
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_KEY=defaultkey
VITE_NAKAMA_SSL=false

# Production example (fill in after deploying Nakama):
# VITE_NAKAMA_HOST=your-nakama-server.com
# VITE_NAKAMA_PORT=443
# VITE_NAKAMA_KEY=your-server-key
# VITE_NAKAMA_SSL=true
